{
  // ReplAI App Store Connect Workflows
  // Bundle ID: com.huseyinataseven.replai
  // Team ID: RS8JSBN29A
  "env": {
    "APP_BUNDLE_ID": "com.huseyinataseven.replai",
    "APP_NAME": "ReplAI",
    "PRIMARY_LOCALE": "en-US",
    "PLATFORM": "IOS"
  },

  "before_all": "asc auth status",

  "workflows": {

    // ── Post-creation setup: categories, age rating, subscriptions ──
    "setup": {
      "description": "Post-app-creation setup: categories, availability, subscriptions",
      "env": {
        "APP_ID": ""
      },
      "steps": [
        {
          "name": "set_categories",
          "run": "asc app-setup categories set --app $APP_ID --primary LIFESTYLE"
        },
        {
          "name": "set_availability",
          "run": "asc app-setup availability set --app $APP_ID --territory USA,GBR,CAN,AUS,DEU,FRA,JPN,KOR,BRA,IND,TUR --available true --available-in-new-territories true"
        },
        {
          "name": "create_subscription_group",
          "run": "asc subscriptions groups create --app $APP_ID --reference-name 'ReplAI Premium' --output json",
          "outputs": {
            "GROUP_ID": "$.data.id"
          }
        },
        {
          "name": "create_weekly_sub",
          "run": "asc subscriptions setup --app $APP_ID --group-id ${steps.create_subscription_group.GROUP_ID} --reference-name 'Weekly' --product-id com.replai.weekly --subscription-period ONE_WEEK --locale en-US --display-name 'Weekly' --price 4.99 --price-territory USA --territories USA,GBR,CAN,AUS,DEU,FRA,JPN,KOR,BRA,IND,TUR"
        },
        {
          "name": "create_monthly_sub",
          "run": "asc subscriptions setup --app $APP_ID --group-id ${steps.create_subscription_group.GROUP_ID} --reference-name 'Monthly' --product-id com.replai.monthly --subscription-period ONE_MONTH --locale en-US --display-name 'Monthly' --price 18.99 --price-territory USA --territories USA,GBR,CAN,AUS,DEU,FRA,JPN,KOR,BRA,IND,TUR"
        },
        {
          "name": "create_yearly_sub",
          "run": "asc subscriptions setup --app $APP_ID --group-id ${steps.create_subscription_group.GROUP_ID} --reference-name 'Yearly' --product-id com.replai.yearly --subscription-period ONE_YEAR --locale en-US --display-name 'Yearly' --price 87.99 --price-territory USA --territories USA,GBR,CAN,AUS,DEU,FRA,JPN,KOR,BRA,IND,TUR"
        }
      ]
    },

    // ── Validate readiness before submission ──
    "preflight": {
      "description": "Validate app version, subscriptions, and metadata before submission",
      "env": {
        "APP_ID": "",
        "VERSION": "1.0"
      },
      "steps": [
        {
          "name": "validate_version",
          "run": "asc validate --app $APP_ID --version $VERSION --platform IOS --output table"
        },
        {
          "name": "validate_subscriptions",
          "run": "asc validate subscriptions --app $APP_ID --output table"
        },
        {
          "name": "status_check",
          "run": "asc status --app $APP_ID --output table"
        }
      ]
    },

    // ── TestFlight distribution ──
    "beta": {
      "description": "Upload latest build to TestFlight",
      "env": {
        "APP_ID": "",
        "GROUP": "Internal Testers"
      },
      "steps": [
        {
          "name": "archive",
          "run": "asc xcode archive --scheme ReplAI --destination generic/platform=iOS"
        },
        {
          "name": "export",
          "run": "asc xcode export --archive-path ${steps.archive.ARCHIVE_PATH} --method app-store"
        },
        {
          "name": "publish",
          "run": "asc publish testflight --app $APP_ID --ipa ${steps.export.IPA_PATH} --group '$GROUP' --wait"
        }
      ]
    },

    // ── Full App Store release ──
    "release": {
      "description": "Full App Store submission pipeline",
      "env": {
        "APP_ID": "",
        "VERSION": "1.0"
      },
      "steps": [
        {
          "workflow": "preflight",
          "with": {
            "APP_ID": "${APP_ID}",
            "VERSION": "${VERSION}"
          }
        },
        {
          "name": "submit",
          "run": "asc release run --app $APP_ID --version $VERSION --platform IOS --confirm"
        }
      ]
    },

    // ── Dashboard: check current status ──
    "status": {
      "description": "Show release pipeline status",
      "env": {
        "APP_ID": ""
      },
      "steps": [
        {
          "name": "dashboard",
          "run": "asc status --app $APP_ID --output table"
        }
      ]
    }
  }
}
